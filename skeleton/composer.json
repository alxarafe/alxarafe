{
    "name": "alxarafe/demo-app",
    "description": "Aplicación de demo y desarrollo para Alxarafe",
    "type": "project",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "firebase/php-jwt": "^7.0",
        "illuminate/database": "^10.48",
        "illuminate/events": "^10.48",
        "illuminate/view": "^10.48",
        "jenssegers/blade": "^2.0",
        "symfony/translation": "^6.4",
        "symfony/var-dumper": "^6.4",
        "symfony/yaml": "^6.4",
        "ext-pdo": "*",
        "erusev/parsedown": "^1.7"
    },
    "replace": {
        "alxarafe/alxarafe": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Alxarafe\\Domain\\": "../src/Domain",
            "Alxarafe\\Application\\": "../src/Application",
            "Alxarafe\\Infrastructure\\": "../src/Infrastructure",
            "Alxarafe\\Scripts\\": "../src/Scripts",
            "Modules\\": ["Modules/", "../src/Modules"]
        }
    },
    "config": {
        "sort-packages": true
    }
}